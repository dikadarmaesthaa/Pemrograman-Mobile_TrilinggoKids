<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/bg_sky_gradient" />
    <item android:gravity="bottom" android:height="280dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/grass_green"
                android:endColor="@color/grass_green_dark"
                android:type="linear" />
            <corners
                android:topLeftRadius="200dp"
                android:topRightRadius="200dp" />
        </shape>
    </item>
</layer-list>
